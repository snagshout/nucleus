{
  "name": "snagshout/nucleus",
  "description": "Some core PHP utilities",
  "license": "MIT",
  "authors": [
    {
      "name": "Eduardo Trujillo",
      "email": "ed@sellerlabs.com"
    }
  ],
  "require": {
    "php": ">=7.3",
    "ext-openssl": "*",
    "ext-mbstring": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.0",
    "mockery/mockery": "^1.5",
    "phpbench/phpbench": "^1.2",
    "ext-http": "*"
  },
  "autoload": {
    "psr-4": {
      "Snagshout\\Nucleus\\": "src/Snagshout/Nucleus"
    },
    "files": [
      "src/Snagshout/Nucleus/Support/intl.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\Snagshout\\Nucleus\\": "tests/Snagshout/Nucleus",
      "Benchmarks\\Snagshout\\Nucleus\\": "benchmarks/Snagshout/Nucleus"
    }
  }
}
